# ============================================================
# CabbageSEO Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# --- Required ---

# OpenAI (GPT-5.4 for all AI features)
OPENAI_API_KEY=sk-...

# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Services ---

# PageSpeed Insights (for SEO audit scores)
GOOGLE_PSI_API_KEY=AIz...

# Google Search Console OAuth (for GSC integration)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# Gemini (for AI Visibility agent — queries Gemini)
GOOGLE_GEMINI_API_KEY=AIz...

# --- Optional LLM Integrations (for AI Visibility) ---

# Anthropic Claude (queries Claude for AI Visibility)
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity (queries Perplexity for AI Visibility)
PERPLEXITY_API_KEY=pplx-...

# --- Optional Integrations ---

# Moz (for real backlink data — free tier: 10 requests/month)
MOZ_API_TOKEN=mozscape-...

# Cron secret (protects /api/cron/scan from unauthorized access)
CRON_SECRET=your-random-secret-string
